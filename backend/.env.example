# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@example.com

# Access Keys
FACULTY_ACCESS_KEY=CDGI-FACULTY-2026
ADMIN_ACCESS_KEY=CDGI-ADMIN-2026
SUPERADMIN_ROOT_KEY=CDGI-HOD-ROOT

# Seeded HOD account
SUPERADMIN_NAME=HOD Super Admin
SUPERADMIN_EMAIL=hod@cdgi.edu.in
SUPERADMIN_PASSWORD=SuperAdmin@2026

# Optional
MAX_FILE_SIZE_MB=10
OPENAI_API_KEY=
COLLEGE_LOGO_PATH=assets/college-logo.png

# File Storage (set to cloudinary for durable file retention)
FILE_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=campusdues
