# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Optional: allow multiple frontend origins (comma-separated)
# FRONTEND_URLS=http://localhost:5173,https://your-frontend-domain.com

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@example.com

# Email reliability (optional)
# Defaults: 10s timeout, 2 retries, 300ms base delay
EMAIL_TIMEOUT_MS=10000
EMAIL_RETRIES=2
EMAIL_RETRY_DELAY_MS=300

# Access Keys
# IMPORTANT (Production): set strong secret keys, do not reuse defaults.
FACULTY_ACCESS_KEY=replace-with-secret-faculty-key
ADMIN_ACCESS_KEY=replace-with-secret-admin-key
SUPERADMIN_ROOT_KEY=replace-with-secret-root-key

# Seeded HOD account
SUPERADMIN_NAME=HOD Super Admin
SUPERADMIN_EMAIL=replace-with-root-hod-email
SUPERADMIN_PASSWORD=replace-with-strong-password

# Optional
MAX_FILE_SIZE_MB=10
OPENAI_API_KEY=
COLLEGE_LOGO_PATH=assets/college-logo.png

# Faculty approval requirements (used for No-Dues submission validation)
# Defaults: Y1/Y2=5, Y3=4, Y4=3
REQUIRED_FACULTY_APPROVALS_Y1Y2=5
REQUIRED_FACULTY_APPROVALS_Y3=4
REQUIRED_FACULTY_APPROVALS_Y4=3

# SLA escalation (notify HOD/Admin if approvals are stuck)
# Defaults: enabled in production, 48h threshold, 15 min sweep, 24h dedupe
SLA_ESCALATION_ENABLED=true
SLA_ESCALATION_HOURS=48
SLA_ESCALATION_INTERVAL_MINUTES=15
SLA_ESCALATION_DEDUPE_HOURS=24

# Prevent duplicate SLA sweeps if Render scales multiple instances
# Default: same as interval minutes
SLA_ESCALATION_LOCK_MINUTES=15

# Index maintenance (advanced)
# Set true ONLY when you intentionally want to run index cleanup tasks.
RUN_INDEX_MAINTENANCE=false

# File Storage (set to cloudinary for durable file retention)
FILE_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=campusdues
